{
  "manifest_version": 3,
  "name": "Ledger Target",
  "version": "1.0",
  "description": "Zero-Knowledge QR Bridge for Ledger",

  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },

  "permissions": [
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "wss://*.piesocket.com/*"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' wss://*.piesocket.com;"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Open Ledger Bridge",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}